{
  "name": "function-archive",
  "version": "1.0.0",
  "description": "FunctionArchive - AI 功能实现工具",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"wait-on http://localhost:5174 && npm run start\"",
    "dev:renderer": "vite",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder",
    "preview": "vite preview"
  },
  "keywords": [],
  "author": "Soyoo AI",
  "license": "MIT",
  "dependencies": {
    "antd": "^5.17.0",
    "@ant-design/pro-layout": "^7.19.4",
    "@ant-design/pro-components": "^2.7.14",
    "@ant-design/icons": "^5.3.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "axios": "^1.7.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.3.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.soyooai.functionarchive",
    "productName": "FunctionArchive",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/main.js",
      "src/preload.js",
      "dist-renderer/**"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
